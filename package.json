{
  "name": "macompare",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:renderer": "vite --config vite.config.ts",
    "dev:main": "tsc -p tsconfig.main.json",
    "dev:main:watch": "tsc -p tsconfig.main.json --watch",
    "dev": "npm run dev:main && concurrently -n renderer,main \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsc -p tsconfig.main.json && node create-main-wrapper.js",
    "build": "npm run build:renderer && npm run build:main",
    "dist:mac": "npm run build && electron-builder --mac",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Tony Xu <tony@tarch.ca>",
  "license": "ISC",
  "description": "A Beyond Compare-like file/folder/Git comparison tool",
  "build": {
    "appId": "ca.tarch.macompare",
    "productName": "MaCompare",
    "copyright": "Copyright © 2026 Tony Xu",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "dist",
      "dist-electron",
      "assets",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "MaCompare",
      "icon": "assets/icon.icns"
    }
  },
  "dependencies": {
    "dir-compare": "^5.0.0",
    "highlight.js": "^11.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.32.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
